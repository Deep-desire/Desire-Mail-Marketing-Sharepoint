# ── Database (Supabase PostgreSQL) ──
# Used for: Admin auth, Templates, Unsubscribed list, Campaign tracking
# Contacts are fetched live from SharePoint — NOT stored here
DATABASE_URL=postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# ── JWT ──
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=24h

# ── Azure Communication Services Email ──
AZURE_CONNECTION_STRING=your-azure-communication-connection-string
AZURE_FROM_EMAIL=donotreply@your-domain.com

# ── SMTP Fallback ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM_NAME="Your From Name"

# ── App ──
FRONTEND_URL=http://localhost:5173
APP_PORT=3000

# ── Microsoft SharePoint (Graph API — Client Credentials) ──
# Azure Portal → Azure Active Directory → Overview → Tenant ID
TENANT_ID=your-tenant-id

# Azure App Registration → Application (client) ID
SP_CLIENT_ID=your-client-id

# Azure App Registration → Certificates & Secrets → Client Secret Value
SP_CLIENT_SECRET=your-client-secret

# SharePoint Site ID  (format: hostname,siteCollectionId,webId)
# Find via: GET https://graph.microsoft.com/v1.0/sites/hostname:/
SP_SITE_ID=your-tenant.sharepoint.com,site-collection-id,web-id

# SharePoint List ID (GUID of the List containing contacts)
# Find via: GET https://graph.microsoft.com/v1.0/sites/{site-id}/lists
SP_LIST_ID=your-list-guid
